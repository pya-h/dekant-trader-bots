# Core runtime
NODE_ENV=production
HOST=0.0.0.0
PORT=3000
ADMIN_SECRET=replace-with-strong-secret
STATE_DIR=state

# External services
DEKANT_BACKEND_URL=https://dekant-api.pyron.fi
PRICESERVICE_URL=https://xprices.umbralabs.io

# Vault
VAULT_SECRET_KEY=replace-with-vault-secret-key

# Bot fleet
BOT_COUNTS=5

# Immutable intervals (require restart to change)
MARKET_REFRESH_INTERVAL_MS=3600000
BUY_INTERVAL_MS=1200000
SELL_INTERVAL_MS=3600000
FUNDING_INTERVAL_MS=3600000
INITIAL_FUNDING_DELAY_MS=30000

# Runtime defaults (copied to state/runtime-config.json on first boot)
BUY_CHANCE=90
SELL_CHANCE=35
MAX_AMOUNT=1000
PREFUND_MULTIPLIER=10
EMERGENCY_TOPUP_COOLDOWN_MS=300000
MIN_BOT_SOL=0.01
VAULT_SUPPORTED_TOKENS=USDT,USDC
STALE_PRICE_POLICY=skip

# HTTP client defaults
PRICE_REQUEST_TIMEOUT_MS=5000
PRICE_RETRY_COUNT=2
PRICE_RETRY_BACKOFF_MS=250

DEKANT_REQUEST_TIMEOUT_MS=8000
DEKANT_RETRY_COUNT=2
DEKANT_RETRY_BACKOFF_MS=300

FAUCET_REQUEST_TIMEOUT_MS=5000
FAUCET_RETRY_COUNT=1
FAUCET_RETRY_BACKOFF_MS=250
